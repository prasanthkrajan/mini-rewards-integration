<div class="container" style="max-width: 900px; margin: 0 auto; background: white; overflow: hidden;">
  <header style="background: white; border-bottom: 1px solid #eee; padding: 20px; display: flex; justify-content: space-between; align-items: center;">
    <div>
      <h1 style="font-size: 24px; margin-bottom: 4px; color: #000;">Points & Rewards</h1>
      <p style="font-size: 13px; color: #666; margin: 0;">Manage your points and rewards</p>
    </div>
    <button
      type="button"
      onclick="handleLogout()"
      style="background: #f5f5f5; color: #000; border: 1px solid #ddd; padding: 8px 16px; border-radius: 4px; cursor: pointer; font-size: 13px; font-weight: 500;"
    >
      Logout
    </button>
  </header>

  <div style="padding: 24px;">
    <!-- Auth Status -->
    <div style="background: #f9f9f9; border: 1px solid #eee; padding: 12px 16px; border-radius: 4px; margin-bottom: 24px; font-size: 13px; color: #666;">
      Logged in as <strong id="userEmailDisplay" style="color: #000;">-</strong>
    </div>

    <!-- Messages -->
    <div id="messages"></div>

    <!-- Balance Panel with Tabs -->
    <div style="background: #f9f9f9; border: 1px solid #eee; border-radius: 4px; margin-bottom: 30px;">
      <!-- Tabs -->
      <div style="display: flex; border-bottom: 1px solid #eee;">
        <button
          id="tab-balance"
          onclick="switchTab('balance')"
          style="flex: 1; padding: 16px; border: none; background: white; color: #000; font-size: 14px; font-weight: 600; cursor: pointer; border-bottom: 2px solid #000;"
        >
          Balance
        </button>
        <button
          id="tab-history"
          onclick="switchTab('history')"
          style="flex: 1; padding: 16px; border: none; background: #f9f9f9; color: #999; font-size: 14px; font-weight: 600; cursor: pointer; border-bottom: 2px solid transparent;"
        >
          History
        </button>
      </div>

      <!-- Balance Tab Content -->
      <div id="balance-content" style="padding: 30px; text-align: center;">
        <p style="font-size: 13px; color: #666; margin-bottom: 12px;">Your Current Balance</p>
        <div class="balance-value" id="balanceValue" style="font-size: 56px; font-weight: bold; color: #000;">-</div>
        <p style="font-size: 12px; color: #999; margin-top: 12px;">Total points available</p>
      </div>

      <!-- History Tab Content -->
      <div id="history-content" style="padding: 20px; display: none;">
        <div style="margin-bottom: 16px;">
          <label style="font-size: 13px; color: #666;">
            Filter by type:
            <select id="transactionKindFilter" onchange="loadTransactions(1)" style="padding: 6px 10px; border: 1px solid #ddd; border-radius: 4px; font-size: 12px; margin-left: 8px;">
              <option value="">All</option>
              <option value="earn">Earned</option>
              <option value="redeem">Redeemed</option>
            </select>
          </label>
        </div>

        <div style="overflow-x: auto;">
          <table id="transactionsTable" style="width: 100%; border-collapse: collapse; font-size: 13px;">
            <thead>
              <tr style="border-bottom: 1px solid #ddd; background: white;">
                <th style="padding: 12px 8px; text-align: left; font-weight: 600; color: #000;">Date</th>
                <th style="padding: 12px 8px; text-align: left; font-weight: 600; color: #000;">Type</th>
                <th style="padding: 12px 8px; text-align: left; font-weight: 600; color: #000;">Activity</th>
                <th style="padding: 12px 8px; text-align: right; font-weight: 600; color: #000;">Points</th>
              </tr>
            </thead>
            <tbody id="transactionsBody">
              <tr><td colspan="4" style="padding: 20px; text-align: center; color: #999;">Loading...</td></tr>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <div id="transactionsPagination" style="margin-top: 16px; text-align: center; font-size: 12px; color: #666;"></div>
      </div>
    </div>

    <!-- Rewards Section -->
    <div class="rewards-section" style="display: none;">
      <h2 style="font-size: 16px; margin-bottom: 16px; color: #000; font-weight: 600;">Available Rewards</h2>
      <div class="rewards-grid" id="rewardsList" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 12px;"></div>
    </div>

    <div id="emptyState" class="empty-state" style="text-align: center; color: #999; padding: 40px 20px;">
      <p style="font-size: 14px;">Loading rewards...</p>
    </div>
  </div>
</div>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    background: white;
    min-height: 100vh;
    padding: 12px;
  }

  .reward-card {
    border: 1px solid #ddd;
    border-radius: 4px;
    padding: 16px;
    background: white;
  }

  .reward-card:hover {
    border-color: #999;
    background: #fafafa;
  }

  .reward-card h3 {
    font-size: 14px;
    color: #000;
    margin-bottom: 6px;
    font-weight: 600;
  }

  .reward-card p {
    font-size: 12px;
    color: #666;
    margin-bottom: 10px;
    min-height: 32px;
    line-height: 1.4;
  }

  .reward-cost {
    display: inline-block;
    background: #f0f0f0;
    color: #000;
    padding: 4px 8px;
    border-radius: 4px;
    font-weight: 600;
    font-size: 12px;
    margin-bottom: 10px;
  }

  .reward-card button {
    width: 100%;
    padding: 8px;
    font-size: 12px;
    background: #000;
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-weight: 600;
    transition: background 0.2s;
  }

  .reward-card button:hover:not(:disabled) {
    background: #333;
  }

  .reward-card button:disabled {
    background: #ccc;
    cursor: not-allowed;
  }

  .message {
    padding: 12px 16px;
    border-radius: 4px;
    margin-bottom: 16px;
    font-size: 13px;
    border: 1px solid #ddd;
  }

  .message.success {
    background: #f0f8f4;
    color: #1a6b4a;
    border-color: #d4e8e0;
  }

  .message.error {
    background: #fef5f5;
    color: #8b2e2e;
    border-color: #e8d4d4;
  }

  .message.info {
    background: #f5f8fd;
    color: #2c4a6b;
    border-color: #d4e0e8;
  }

  @media (max-width: 600px) {
    .rewards-grid {
      grid-template-columns: 1fr !important;
    }

    header {
      flex-direction: column !important;
      align-items: flex-start !important;
    }

    button {
      align-self: flex-end;
      margin-top: 12px;
    }
  }
</style>

<script>
  const API_BASE = 'http://localhost:3000';
  let authToken = localStorage.getItem('authToken');
  let currentBalance = 0;

  // Check if user is logged in
  if (!authToken) {
    window.location.href = '/login';
  }

  // Display user email
  const userEmail = localStorage.getItem('userEmail');
  if (userEmail) {
    document.getElementById('userEmailDisplay').textContent = userEmail;
  }

  function switchTab(tab) {
    const balanceContent = document.getElementById('balance-content');
    const historyContent = document.getElementById('history-content');
    const balanceTab = document.getElementById('tab-balance');
    const historyTab = document.getElementById('tab-history');

    if (tab === 'balance') {
      balanceContent.style.display = 'block';
      historyContent.style.display = 'none';
      balanceTab.style.background = 'white';
      balanceTab.style.color = '#000';
      balanceTab.style.borderBottom = '2px solid #000';
      historyTab.style.background = '#f9f9f9';
      historyTab.style.color = '#999';
      historyTab.style.borderBottom = '2px solid transparent';
    } else {
      balanceContent.style.display = 'none';
      historyContent.style.display = 'block';
      balanceTab.style.background = '#f9f9f9';
      balanceTab.style.color = '#999';
      balanceTab.style.borderBottom = '2px solid transparent';
      historyTab.style.background = 'white';
      historyTab.style.color = '#000';
      historyTab.style.borderBottom = '2px solid #000';
    }
  }

  async function loadBalance() {
    try {
      const response = await fetch(`${API_BASE}/api/me/balance`, {
        headers: {
          'Authorization': `Bearer ${authToken}`
        }
      });

      if (!response.ok) throw new Error('Failed to load balance');

      const data = await response.json();
      currentBalance = data.balance;
      document.getElementById('balanceValue').textContent = data.balance;
    } catch (error) {
      showMessage(`Error loading balance: ${error.message}`, 'error');
    }
  }

  async function loadRewards() {
    try {
      const response = await fetch(`${API_BASE}/api/rewards`);
      if (!response.ok) throw new Error('Failed to load rewards');

      const rewards = await response.json();
      displayRewards(rewards);
    } catch (error) {
      showMessage(`Error loading rewards: ${error.message}`, 'error');
    }
  }

  function displayRewards(rewards) {
    const rewardsList = document.getElementById('rewardsList');
    rewardsList.innerHTML = '';

    if (rewards.length === 0) {
      rewardsList.innerHTML = '<p style="color: #999;">No rewards available</p>';
      return;
    }

    rewards.forEach(reward => {
      const canRedeem = currentBalance >= reward.points_required;
      const card = document.createElement('div');
      card.className = 'reward-card';
      card.innerHTML = `
        <h3>${reward.name}</h3>
        <p>${reward.description || 'A great reward'}</p>
        <div class="reward-cost">${reward.points_required} points</div>
        <button
          onclick="redeemReward(${reward.id}, '${reward.name}', ${reward.points_required})"
          ${!canRedeem ? 'disabled' : ''}
        >
          ${canRedeem ? 'Redeem' : 'Not Enough Points'}
        </button>
      `;
      rewardsList.appendChild(card);
    });

    document.getElementById('emptyState').style.display = 'none';
    document.querySelector('.rewards-section').style.display = 'block';
  }

  async function redeemReward(rewardId, rewardName, pointsCost) {
    try {
      const response = await fetch(`${API_BASE}/api/rewards/${rewardId}/redeem`, {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${authToken}`,
          'Content-Type': 'application/json'
        }
      });

      if (!response.ok) {
        const error = await response.json();
        throw new Error(error.error || 'Redemption failed');
      }

      const data = await response.json();
      showMessage(`✓ Redeemed "${rewardName}" for ${data.points_spent} points. New balance: ${data.new_balance}`, 'success');

      currentBalance = data.new_balance;
      document.getElementById('balanceValue').textContent = data.new_balance;
      loadRewards();
    } catch (error) {
      showMessage(`Error redeeming reward: ${error.message}`, 'error');
    }
  }

  function showMessage(text, type) {
    const messagesDiv = document.getElementById('messages');
    const message = document.createElement('div');
    message.className = `message ${type}`;
    message.textContent = text;
    messagesDiv.appendChild(message);

    setTimeout(() => message.remove(), 5000);
  }

  function handleLogout() {
    localStorage.clear();
    window.location.href = '/login';
  }

  async function loadTransactions(page = 1) {
    try {
      const kind = document.getElementById('transactionKindFilter').value;
      const params = new URLSearchParams({ page });
      if (kind) params.append('kind', kind);

      const response = await fetch(`${API_BASE}/api/me/transactions?${params}`, {
        headers: {
          'Authorization': `Bearer ${authToken}`
        }
      });

      if (!response.ok) throw new Error('Failed to load transactions');

      const data = await response.json();
      displayTransactions(data.transactions);
      displayPagination(data.pagination, page);
    } catch (error) {
      showMessage(`Error loading transactions: ${error.message}`, 'error');
    }
  }

  function displayTransactions(transactions) {
    const tbody = document.getElementById('transactionsBody');
    tbody.innerHTML = '';

    if (transactions.length === 0) {
      tbody.innerHTML = '<tr><td colspan="4" style="padding: 20px; text-align: center; color: #999;">No transactions yet</td></tr>';
      return;
    }

    transactions.forEach(tx => {
      const date = new Date(tx.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
      const points = tx.points_delta;
      const pointsSign = points > 0 ? '+' : '';
      const type = tx.kind === 'earn' ? 'Earned' : 'Redeemed';
      const activity = tx.activity_type.replace(/_/g, ' ');

      const row = document.createElement('tr');
      row.style.borderBottom = '1px solid #eee';
      row.innerHTML = `
        <td style="padding: 12px 8px; color: #666;">${date}</td>
        <td style="padding: 12px 8px; font-weight: 600; color: #000;">${type}</td>
        <td style="padding: 12px 8px; color: #666; text-transform: capitalize;">${activity}</td>
        <td style="padding: 12px 8px; text-align: right; font-weight: 600; color: #000;">${pointsSign}${points}</td>
      `;
      tbody.appendChild(row);
    });
  }

  function displayPagination(pagination, currentPage) {
    const container = document.getElementById('transactionsPagination');
    container.innerHTML = '';

    if (pagination.total_pages <= 1) {
      container.innerHTML = `<p style="margin: 0; color: #666;">Showing ${pagination.total_count} transaction${pagination.total_count !== 1 ? 's' : ''}</p>`;
      return;
    }

    const pages = [];
    if (currentPage > 1) {
      pages.push(`<a href="#" onclick="loadTransactions(${currentPage - 1}); return false;" style="color: #000; text-decoration: none; margin-right: 12px;">← Previous</a>`);
    }

    pages.push(`<span style="margin: 0 12px; color: #666;">Page ${currentPage} of ${pagination.total_pages}</span>`);

    if (currentPage < pagination.total_pages) {
      pages.push(`<a href="#" onclick="loadTransactions(${currentPage + 1}); return false;" style="color: #000; text-decoration: none; margin-left: 12px;">Next →</a>`);
    }

    container.innerHTML = pages.join('');
  }

  // Load data on page load
  loadBalance();
  loadRewards();
  loadTransactions(1);
</script>
