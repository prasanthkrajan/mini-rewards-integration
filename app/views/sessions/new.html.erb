<div style="max-width: 400px; margin: 50px auto; padding: 20px;">
  <header style="text-align: center; margin-bottom: 40px;">
    <h1 style="font-size: 28px; margin-bottom: 8px; color: #000;">Points & Rewards</h1>
    <p style="font-size: 13px; color: #666;">Sign in to manage your points</p>
  </header>

  <% if notice %>
    <div style="background: #f0f8f4; color: #1a6b4a; border: 1px solid #d4e8e0; border-radius: 4px; padding: 12px 16px; margin-bottom: 20px; font-size: 13px;">
      <%= notice %>
    </div>
  <% end %>

  <% if alert %>
    <div style="background: #fef5f5; color: #8b2e2e; border: 1px solid #e8d4d4; border-radius: 4px; padding: 12px 16px; margin-bottom: 20px; font-size: 13px;">
      <%= alert %>
    </div>
  <% end %>

  <div id="messages"></div>

  <div style="background: white; border: 1px solid #eee; padding: 24px; border-radius: 4px;">
    <h2 style="font-size: 16px; margin-bottom: 20px; color: #000; font-weight: 600;">Login</h2>

    <div style="display: flex; flex-direction: column; gap: 12px;">
      <input
        type="email"
        id="emailInput"
        placeholder="Email"
        required
        style="padding: 10px 12px; border: 1px solid #ddd; border-radius: 4px; font-size: 13px;"
      >

      <input
        type="password"
        id="passwordInput"
        placeholder="Password"
        required
        style="padding: 10px 12px; border: 1px solid #ddd; border-radius: 4px; font-size: 13px;"
      >

      <button
        type="button"
        onclick="handleLogin()"
        style="width: 100%; padding: 10px; background: #000; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 13px; font-weight: 600; margin-top: 8px;"
      >
        Sign In
      </button>
    </div>

    <p style="text-align: center; margin-top: 16px; font-size: 12px; color: #666;">
      Demo: alice@example.com / alice123
    </p>
  </div>
</div>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    background: white;
    min-height: 100vh;
  }
</style>

<script>
  const API_BASE = 'http://localhost:3000';

  async function handleLogin() {
    const email = document.getElementById('emailInput').value.trim();
    const password = document.getElementById('passwordInput').value.trim();

    if (!email || !password) {
      showMessage('Please enter both email and password', 'error');
      return;
    }

    try {
      const response = await fetch(`${API_BASE}/api/login`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ email, password })
      });

      if (!response.ok) {
        const error = await response.json();
        throw new Error(error.error || 'Login failed');
      }

      const data = await response.json();
      const token = data.token;

      // Store JWT in localStorage
      localStorage.setItem('authToken', token);
      localStorage.setItem('userEmail', data.user.email);
      localStorage.setItem('userName', data.user.name);

      // Redirect to home
      window.location.href = '/home';
    } catch (error) {
      showMessage(`Login failed: ${error.message}`, 'error');
      document.getElementById('passwordInput').value = '';
    }
  }

  function showMessage(text, type) {
    const messagesDiv = document.getElementById('messages');
    const message = document.createElement('div');
    message.style.cssText = `
      background: ${type === 'error' ? '#fef5f5' : '#f0f8f4'};
      color: ${type === 'error' ? '#8b2e2e' : '#1a6b4a'};
      border: 1px solid ${type === 'error' ? '#e8d4d4' : '#d4e8e0'};
      border-radius: 4px;
      padding: 12px 16px;
      margin-bottom: 20px;
      font-size: 13px;
    `;
    message.textContent = text;
    messagesDiv.appendChild(message);

    setTimeout(() => message.remove(), 5000);
  }

  // If already logged in, redirect to home
  if (localStorage.getItem('authToken')) {
    window.location.href = '/home';
  }
</script>
